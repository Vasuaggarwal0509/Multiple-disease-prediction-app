{
  "diseases": {
    "diabetes": {
      "name": "Diabetes",
      "type": "tabular",
      "description": "Prediction of diabetes onset using clinical measurements from the Pima Indians Diabetes Database.",
      "dataset": {
        "name": "Pima Indians Diabetes Database",
        "source": "UCI ML Repository / Kaggle",
        "url": "https://www.kaggle.com/datasets/uciml/pima-indians-diabetes-database",
        "samples": 768,
        "features": 8,
        "classes": [
          "Not Diabetic",
          "Diabetic"
        ]
      },
      "features": [
        {
          "name": "Pregnancies",
          "label": "Number of Pregnancies",
          "type": "int"
        },
        {
          "name": "Glucose",
          "label": "Glucose Level (mg/dL)",
          "type": "float"
        },
        {
          "name": "BloodPressure",
          "label": "Blood Pressure (mm Hg)",
          "type": "float"
        },
        {
          "name": "SkinThickness",
          "label": "Skin Thickness (mm)",
          "type": "float"
        },
        {
          "name": "Insulin",
          "label": "Insulin Level (mu U/ml)",
          "type": "float"
        },
        {
          "name": "BMI",
          "label": "BMI (kg/m\u00b2)",
          "type": "float"
        },
        {
          "name": "DiabetesPedigreeFunction",
          "label": "Diabetes Pedigree Function",
          "type": "float"
        },
        {
          "name": "Age",
          "label": "Age (years)",
          "type": "int"
        }
      ],
      "models": {
        "svm": {
          "name": "Support Vector Machine",
          "file": "ml_models/diabetes/svm_model.sav",
          "format": "pickle"
        }
      }
    },
    "heart": {
      "name": "Heart Disease",
