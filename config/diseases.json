          "type": "int"
        },
        {
          "name": "cp",
          "label": "Chest Pain Type (0-3)",
          "type": "int"
        },
        {
          "name": "trestbps",
          "label": "Resting Blood Pressure (mm Hg)",
          "type": "float"
        },
        {
          "name": "chol",
          "label": "Serum Cholesterol (mg/dL)",
          "type": "float"
        },
        {
          "name": "fbs",
