    "eye_disease": {
      "name": "Eye Disease (OCT)",
      "type": "image",
      "description": "Classification of retinal diseases from Optical Coherence Tomography (OCT) images. Identifies CNV, DME, DRUSEN, and Normal retinal conditions.",
      "dataset": {
        "name": "Kermany OCT Retinal Images",
        "source": "Kaggle (Kermany et al., 2018)",
        "url": "https://www.kaggle.com/datasets/anirudhcv/labeled-optical-coherence-tomography-oct",
        "classes": [
          "CNV",
          "DME",
          "DRUSEN",
          "NORMAL"
        ],
        "image_size": [
          224,
          224
        ]
      },
      "models": {
        "trained": {
          "name": "MobileNet V3 (fine-tuned)",
          "file": "ml_models/eye_disease/trained_model.keras",
          "fallback_file": "ml_models/eye_disease/trained_model.h5",
          "format": "keras",
          "input_size": [
            224,
            224,
            3
          ],
          "preprocess": "mobilenet_v3"
        }
      }
    },
    "pneumonia": {
